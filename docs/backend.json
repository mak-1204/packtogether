{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents non-sensitive user profile data.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["id", "firstName"]
    },
    "Trip": {
      "title": "Trip",
      "type": "object",
      "description": "Represents a single trip plan.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "destination": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "budgetPerHead": { "type": "number" },
        "vibe": { "type": "string" },
        "organizerId": { "type": "string" },
        "status": { "type": "string" },
        "coverImageUrl": { "type": "string" },
        "members": { "type": "object", "additionalProperties": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "destination", "organizerId"]
    },
    "ItineraryItem": {
      "title": "ItineraryItem",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "dayNumber": { "type": "number" },
        "timeSlot": { "type": "string", "enum": ["Morning", "Afternoon", "Evening", "Night"] },
        "plannedBudget": { "type": "number" },
        "actualBudget": { "type": "number" },
        "notes": { "type": "string" }
      }
    },
    "Suggestion": {
      "title": "Suggestion",
      "type": "object",
      "description": "A link or idea shared by trip members.",
      "properties": {
        "link": { "type": "string" },
        "notes": { "type": "string" },
        "addedBy": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" },
        "aiRecommended": { "type": "boolean" },
        "aiReason": { "type": "string" }
      }
    },
    "PackingItem": {
      "title": "PackingItem",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "isPacked": { "type": "boolean" },
        "addedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Stores user profiles."
    },
    "/trips/{tripId}": {
      "schema": { "$ref": "#/backend/entities/Trip" },
      "description": "Main trip document."
    },
    "/trips/{tripId}/itineraryItems/{itemId}": {
      "schema": { "$ref": "#/backend/entities/ItineraryItem" },
      "description": "Trip activities."
    },
    "/trips/{tripId}/itineraryItems/{itemId}/suggestions/{suggestionId}": {
      "schema": { "$ref": "#/backend/entities/Suggestion" },
      "description": "Specific options for an itinerary activity."
    },
    "/trips/{tripId}/suggestions/{suggestionId}": {
      "schema": { "$ref": "#/backend/entities/Suggestion" },
      "description": "General trip suggestions."
    },
    "/trips/{tripId}/packingItems/{packingItemId}": {
      "schema": { "$ref": "#/backend/entities/PackingItem" },
      "description": "Shared packing list items."
    }
  }
}