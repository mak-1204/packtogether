
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PACKTOGETHER SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOrganizer(data) {
      return isSignedIn() && data.organizerId == request.auth.uid;
    }

    function isMember(data) {
      return isSignedIn() && (data.organizerId == request.auth.uid || (data.members != null && data.members[request.auth.uid] != null));
    }

    /** @description Slideshow for landing page. */
    match /slideshow/{slideId} {
      allow read: if true;
      allow write: if false;
    }

    /** @description Standard user profile path. */
    match /users/{userId} {
      allow get, list, write: if isOwner(userId);
    }

    match /trips/{tripId} {
      allow get: if true; // Allow public view for /join and /view
      allow list: if isSignedIn() && (resource.data.organizerId == request.auth.uid || (resource.data.members != null && resource.data.members[request.auth.uid] != null));
      allow create: if isSignedIn();
      allow update: if isMember(resource.data);
      allow delete: if isOrganizer(resource.data);

      match /members/{memberId} {
        allow get, list: if true;
        allow create: if true; // Anyone can join via link
        allow update, delete: if isSignedIn();
      }

      match /itineraryItems/{itemId} {
        allow get, list: if true;
        allow create, update, delete: if true; // Collaborative
        
        match /checklistItems/{checklistItemId} {
           allow get, list, write: if true;
        }
      }

      match /suggestions/{suggestionId} {
        allow get, list: if true;
        allow create, update, delete: if true;
      }

      match /packingItems/{packingItemId} {
        allow get, list: if true;
        allow create, update, delete: if true;
      }
    }

    match /public_trip_summaries/{tripId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
