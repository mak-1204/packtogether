
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PACKTOGETHER SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if user is the organizer or a member of a trip
    // tripData is the data of the trip document
    function isMember(tripData) {
      return isSignedIn() && (
        tripData.organizerId == request.auth.uid || 
        (tripData.members != null && tripData.members[request.auth.uid] != null)
      );
    }

    // Helper to check if user is specifically the organizer
    function isOrganizer(tripData) {
      return isSignedIn() && tripData.organizerId == request.auth.uid;
    }

    /** @description Slideshow for landing page. */
    match /slideshow/{slideId} {
      allow read: if true;
      allow write: if false;
    }

    /** @description Standard user profile path. */
    match /users/{userId} {
      allow get, list, write: if isSignedIn() && request.auth.uid == userId;
    }

    /** @description Trip records and subcollections. */
    match /trips/{tripId} {
      // Anyone can 'get' a trip for public viewing/joining via link
      allow get: if true;
      
      // Listing trips (e.g., on the dashboard) is restricted to members/organizers
      allow list: if isSignedIn();
      
      allow create: if isSignedIn();
      allow update: if isMember(resource.data);
      allow delete: if isOrganizer(resource.data);

      // Members subcollection - public list to see who is on the trip
      match /members/{memberId} {
        allow read: if true;
        allow create: if true;    // Anyone can join via link
        allow update, delete: if isSignedIn();
      }

      // Itinerary subcollection - public read for "Shareable Link" viewing
      match /itineraryItems/{itemId} {
        allow read: if true;
        allow write: if isSignedIn(); 
        
        match /checklistItems/{checklistItemId} {
           allow read: if true;
           allow write: if isSignedIn();
        }
      }

      // Suggestions subcollection - public read for "Shareable Link" viewing
      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      // Packing subcollection - public read for "Shareable Link" viewing
      match /packingItems/{packingItemId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    /** @description Read-only summaries for cloning. */
    match /public_trip_summaries/{tripId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
