rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PACKTOGETHER SECURITY RULES
     * Updated to allow multiple admins and handle nested subcollections.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if user is a member of a trip
    function isMember(tripData) {
      return isSignedIn() && (
        tripData.organizerId == request.auth.uid || 
        (tripData.members != null && tripData.members[request.auth.uid] != null)
      );
    }

    // Helper to check if user is an admin or organizer
    function isAdmin(tripData) {
      return isSignedIn() && (
        tripData.organizerId == request.auth.uid || 
        (tripData.members != null && tripData.members[request.auth.uid] == 'admin')
      );
    }

    /** @description Slideshow for landing page. */
    match /slideshow/{slideId} {
      allow read: if true;
      allow write: if false;
    }

    /** @description Standard user profile path. */
    match /users/{userId} {
      allow get, list, write: if isSignedIn() && request.auth.uid == userId;
    }

    /** @description Trip records and subcollections. */
    match /trips/{tripId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      
      // Allow update if admin or if a signed-in user is joining
      allow update: if isAdmin(resource.data) || isMember(resource.data) || isSignedIn();
      
      allow delete: if isAdmin(resource.data);

      match /members/{memberId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (request.auth.uid == memberId || isAdmin(get(/databases/$(database)/documents/trips/$(tripId)).data));
      }

      match /itineraryItems/{itemId} {
        allow read: if true; 
        allow write: if isMember(get(/databases/$(database)/documents/trips/$(tripId)).data); 
        
        match /checklistItems/{checklistItemId} {
           allow read: if true;
           allow write: if isMember(get(/databases/$(database)/documents/trips/$(tripId)).data);
        }

        match /suggestions/{suggestionId} {
           allow read: if true;
           allow write: if isMember(get(/databases/$(database)/documents/trips/$(tripId)).data);
        }
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if isMember(get(/databases/$(database)/documents/trips/$(tripId)).data);
      }

      match /packingItems/{packingItemId} {
        allow read: if true;
        allow write: if isMember(get(/databases/$(database)/documents/trips/$(tripId)).data);
      }
    }

    /** @description Read-only summaries for cloning. */
    match /public_trip_summaries/{tripId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
